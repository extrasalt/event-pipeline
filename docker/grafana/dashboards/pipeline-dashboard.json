{
  "title": "Pipeline & Events",
  "uid": "pipeline-events",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "title": "Insert Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(clickhouse_inserts_total[1m])",
          "legendFormat": "inserts/s"
        }
      ]
    },
    {
      "title": "Insert Latency (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(clickhouse_insert_latency_seconds_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(clickhouse_insert_latency_seconds_bucket[1m]))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, rate(clickhouse_insert_latency_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "rate(clickhouse_insert_errors_total[1m])",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "clickhouse_queue_depth",
          "legendFormat": "queued"
        }
      ]
    },
    {
      "title": "Events Over Time",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 9, "x": 6, "y": 8},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "rawSql": true,
          "query": "SELECT toDate(timestamp) AS t, count() AS c FROM default.events GROUP BY t ORDER BY t",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Events by Type",
      "type": "barchart",
      "gridPos": {"h": 6, "w": 9, "x": 15, "y": 8},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "rawSql": true,
          "query": "SELECT type, count() AS c FROM default.events GROUP BY type ORDER BY c DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"axisBorderShow": false}
        }
      }
    },
    {
      "title": "Total Events",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 14},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "rawSql": true,
          "query": "SELECT count() FROM default.events",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Capture Time (ms)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 14},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "rawSql": true,
          "query": "SELECT round(avg(dateDiff('millisecond', timestamp, inserted_at)), 2) FROM default.events",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Event Params",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 14},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "rawSql": true,
          "query": "SELECT round(avg(param_count), 2) FROM default.events",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
