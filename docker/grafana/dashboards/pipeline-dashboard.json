{
  "title": "Pipeline & Events",
  "uid": "pipeline-events",
  "schemaVersion": 39,
  "version": 3,
  "timezone": "browser",
  "panels": [
    {
      "title": "Insert Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(chdb_inserts_total[1m])",
          "legendFormat": "inserts/s"
        }
      ]
    },
    {
      "title": "Insert Latency (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(chdb_insert_latency_seconds_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(chdb_insert_latency_seconds_bucket[1m]))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, rate(chdb_insert_latency_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "rate(chdb_insert_errors_total[1m])",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "chdb_queue_depth",
          "legendFormat": "queued"
        }
      ]
    },
    {
      "title": "Events Over Time",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 9, "x": 6, "y": 8},
      "targets": [
        {
          "datasource": {
            "type": "grafana-json-datasource",
            "uid": "PIPELINE_API"
          },
          "queryParams": "metric=events_over_time",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Events by Type",
      "type": "barchart",
      "gridPos": {"h": 6, "w": 9, "x": 15, "y": 8},
      "targets": [
        {
          "datasource": {
            "type": "grafana-json-datasource",
            "uid": "PIPELINE_API"
          },
          "queryParams": "metric=events_by_type",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"axisBorderShow": false}
        }
      }
    },
    {
      "title": "Total Events",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 14},
      "targets": [
        {
          "datasource": {
            "type": "grafana-json-datasource",
            "uid": "PIPELINE_API"
          },
          "queryParams": "metric=total_events",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Capture Time (ms)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 14},
      "targets": [
        {
          "datasource": {
            "type": "grafana-json-datasource",
            "uid": "PIPELINE_API"
          },
          "queryParams": "metric=avg_capture_time_ms",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Event Params",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 14},
      "targets": [
        {
          "datasource": {
            "type": "grafana-json-datasource",
            "uid": "PIPELINE_API"
          },
          "queryParams": "metric=avg_event_params",
          "refId": "A"
        }
      ]
    }
  ]
}
